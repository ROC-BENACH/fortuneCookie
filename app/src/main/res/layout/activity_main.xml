<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- Theme toggle button hidden to match the screenshot accurately -->
    <ImageButton
        android:id="@+id/btnThemeToggle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <!-- ── Botones de acción (Top row) ── -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnReload"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_reload"
            android:background="@drawable/button_circle_brown"
            android:contentDescription="Nova frase"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnCopy"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_copy"
            android:background="@drawable/button_circle_brown"
            android:contentDescription="Copiar"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_share"
            android:background="@drawable/button_circle_brown"
            android:contentDescription="Compartir"
            android:padding="14dp"
            android:scaleType="fitCenter"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- ── Header: título + subtítulo ── -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Galeta de la Fortuna"
        android:textColor="#8B6C4F"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/buttonLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Descobreix què et depara el futur avui"
        android:textColor="#D89A63"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Contenedor de la galleta ── -->
    <ImageView
        android:id="@+id/ivCookie"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/cookie_closed"
        android:contentDescription="Galleta de la fortuna"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/cardFortune"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Card de la fortuna ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFortune"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="64dp"
        app:cardBackgroundColor="#FCF6EF"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EL TEU DESTÍ"
                android:textColor="#8B6C4F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvFortune"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Un viatge de mil quilòmetres comença amb un sol pas."
                android:textColor="#424242"
                android:textSize="20sp"
                android:gravity="center"
                android:lineSpacingExtra="8dp"
                android:fontFamily="serif"
                android:textStyle="italic"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>